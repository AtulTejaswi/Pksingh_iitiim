generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

// Role is stored as String: SUPER_ADMIN, INSTRUCTOR, MENTOR, STUDENT
// PublishStatus is stored as String: DRAFT, PUBLISHED, ARCHIVED
// QueryStatus is stored as String: OPEN, IN_PROGRESS, RESOLVED, CLOSED
// EventType is stored as String: LIVE_CLASS, WEBINAR, WORKSHOP, COUNSELING

// ─── USERS ───────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  supabaseId    String   @unique          // Links to Supabase Auth UID or local auth identifier
  passwordHash  String?                           // Local development password hash
  email         String   @unique
  fullName      String
  role          String   @default("STUDENT")
  avatarUrl     String?
  country       String?                  // "IN" or "US" for content targeting
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  enrollments   Enrollment[]
  progress      LessonProgress[]
  queries       StudentQuery[]
  authoredBlogs Blog[]
  certificates  Certificate[]
  reviews       Review[]

  @@map("users")
}

// ─── COURSES ─────────────────────────────────────────────────────────────────

model Course {
  id           String        @id @default(uuid())
  title        String
  description  String
  subject      String
  difficulty   String?
  duration     String?       // E.g., "10 hours", "4 weeks"
  language     String?
  categoryId   String?
  category     Category?     @relation(fields: [categoryId], references: [id])
  tags         CourseTag[]
  thumbnailUrl String?
  isFree       Boolean       @default(false)
  status       String   @default("DRAFT")
  sortOrder    Int           @default(0)
  prerequisites String?      // JSON or text
  learningOutcomes String?   // JSON or text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  lessons      Lesson[]
  enrollments  Enrollment[]
  reviews      Review[]

  @@index([status])
  @@index([categoryId])
  @@map("courses")
}

// ─── CATEGORIES & TAGS ───────────────────────────────────────────────────────

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  courses   Course[]
  blogs     Blog[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Tag {
  id        String      @id @default(uuid())
  name      String      @unique
  slug      String      @unique
  courses   CourseTag[]
  blogs     BlogTag[]
  media     MediaAssetTag[]
  createdAt DateTime    @default(now())
  
  @@map("tags")
}

model CourseTag {
  courseId String
  tagId    String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([courseId, tagId])
  @@map("course_tags")
}

// ─── LESSONS ─────────────────────────────────────────────────────────────────

model Lesson {
  id           String        @id @default(uuid())
  courseId     String
  title        String
  description  String?
  content      String?       // Rich text / Markdown body
  sortOrder    Int           @default(0)
  isFree       Boolean       @default(false)
  status       String   @default("DRAFT")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  course       Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  media        LessonMedia[]
  notes        Note[]
  progress     LessonProgress[]

  @@index([courseId, status])
  @@map("lessons")
}

// ─── CENTRALIZED MEDIA LIBRARY ───────────────────────────────────────────────

model MediaAsset {
  id          String   @id @default(uuid())
  title       String
  type        String   // IMAGE, VIDEO, PDF, DOC
  url         String   // Cloudinary/S3 URL
  storagePath String?  // Provider path for deletion
  sizeBytes   Int?
  mimeType    String?
  folder      String   @default("/")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tags        MediaAssetTag[]
  lessonMedia LessonMedia[]
  
  @@index([folder])
  @@map("media_assets")
}

model MediaAssetTag {
  mediaId String
  tagId   String
  media   MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  tag     Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([mediaId, tagId])
  @@map("media_asset_tags")
}

model LessonMedia {
  id           String     @id @default(uuid())
  lessonId     String
  mediaAssetId String
  sortOrder    Int        @default(0)
  
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@map("lesson_media")
}

// ─── NOTES ───────────────────────────────────────────────────────────────────

model Note {
  id        String   @id @default(uuid())
  lessonId  String
  title     String
  content   String
  fileUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("notes")
}

// ─── ENROLLMENTS & PROGRESS ──────────────────────────────────────────────────

model Enrollment {
  id          String    @id @default(uuid())
  userId      String
  courseId    String
  status      String    @default("ACTIVE")
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  user        User      @relation(fields: [userId], references: [id])
  course      Course    @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@map("enrollments")
}

model LessonProgress {
  id          String   @id @default(uuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  lesson      Lesson   @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

model Certificate {
  id           String   @id @default(uuid())
  certificateId String  @unique // Public unique ID
  userId       String
  courseId     String
  issuedAt     DateTime @default(now())
  pdfUrl       String?

  user         User     @relation(fields: [userId], references: [id])
  
  @@unique([userId, courseId])
  @@map("certificates")
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  rating    Int      // 1-5
  comment   String?
  isApproved Boolean @default(true) // For moderation
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@map("reviews")
}

// ─── CMS: PAGES & SECTIONS (HOMEPAGE BUILDER) ──────────────────────────────

model Page {
  id              String   @id @default(uuid())
  title           String
  slug            String   @unique
  status          PublishStatus @default(DRAFT)
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogImageUrl      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sections        PageSection[]

  @@map("cms_pages")
}

model PageSection {
  id          String   @id @default(uuid())
  pageId      String
  type        String   // HERO, BANNER, CTA, FEATURES, TESTIMONIALS
  content     String   // JSON containing specific data for the section type
  sortOrder   Int      @default(0)
  isHidden    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  page        Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@map("cms_page_sections")
}

// ─── CMS: BLOGS ─────────────────────────────────────────────────────────────

model Blog {
  id              String   @id @default(uuid())
  title           String
  slug            String   @unique
  content         String   // Rich Text
  authorId        String
  categoryId      String?
  status          PublishStatus @default(DRAFT)
  featuredImage   String?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  publishedAt     DateTime?

  author          User      @relation(fields: [authorId], references: [id])
  category        Category? @relation(fields: [categoryId], references: [id])
  tags            BlogTag[]

  @@map("cms_blogs")
}

model BlogTag {
  blogId String
  tagId  String
  blog   Blog @relation(fields: [blogId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blogId, tagId])
  @@map("cms_blog_tags")
}

// ─── CMS: ANNOUNCEMENTS & FAQS ──────────────────────────────────────────────

model Announcement {
  id          String   @id @default(uuid())
  title       String
  content     String   // Rich Text
  attachmentUrl String?
  status      PublishStatus @default(DRAFT)
  scheduledFor DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cms_announcements")
}

model FAQ {
  id          String   @id @default(uuid())
  question    String
  answer      String   // Rich text
  category    String   // e.g. "General", "Payments"
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cms_faqs")
}

model Testimonial {
  id          String   @id @default(uuid())
  name        String
  studentPhoto String?
  rank        String?
  achievement String?
  review      String
  status      PublishStatus @default(DRAFT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cms_testimonials")
}

// ─── EVENTS & HELPDESK ──────────────────────────────────────────────────────

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  type        String
  meetingLink String?
  startsAt    DateTime
  endsAt      DateTime
  status      PublishStatus @default(DRAFT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("events")
}

model StudentQuery {
  id          String   @id @default(uuid())
  userId      String
  subject     String
  message     String
  status      String @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  replies     QueryReply[]

  @@map("student_queries")
}

model QueryReply {
  id          String   @id @default(uuid())
  queryId     String
  authorId    String   // Could be user or mentor
  message     String
  createdAt   DateTime @default(now())

  query       StudentQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)

  @@map("student_query_replies")
}

// ─── AUDIT LOG ───────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String   // LOGIN, COURSE_CREATE, etc.
  details     String?  // JSON context
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([action, createdAt])
  @@map("audit_logs")
}
