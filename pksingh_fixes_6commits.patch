From e59a9ff60fcd2bc7407d831f517d2fa59e625f45 Mon Sep 17 00:00:00 2001
From: AtulTejaswi <tejaswiatul22@gmail.com>
Date: Tue, 2 Jun 2026 21:05:23 +0530
Subject: [PATCH 6/6] fix(ci): add postgres service and run prisma db push

---
 .github/workflows/ci.yml | 17 +++++++++++++++++
 render.yaml              |  4 ++--
 2 files changed, 19 insertions(+), 2 deletions(-)

diff --git a/.github/workflows/ci.yml b/.github/workflows/ci.yml
index 912c359..70ebe41 100644
--- a/.github/workflows/ci.yml
+++ b/.github/workflows/ci.yml
@@ -11,6 +11,20 @@ jobs:
     runs-on: ubuntu-latest
     env:
       DATABASE_URL: postgresql://ci:ci@localhost:5432/ci_test
+    services:
+      postgres:
+        image: postgres:15
+        env:
+          POSTGRES_USER: ci
+          POSTGRES_PASSWORD: ci
+          POSTGRES_DB: ci_test
+        ports:
+          - 5432:5432
+        options: >-
+          --health-cmd "pg_isready -U ci -d ci_test"
+          --health-interval 10s
+          --health-timeout 5s
+          --health-retries 5
     strategy:
       matrix:
         node-version: [18.x]
@@ -23,6 +37,9 @@ jobs:
       - name: Install dependencies
         run: |
           npm ci
+      - name: Prepare database schema (CI only)
+        run: |
+          npx prisma db push
       - name: Build backend
         run: npm run build
       - name: Build frontend
diff --git a/render.yaml b/render.yaml
index e93de20..9a8d228 100644
--- a/render.yaml
+++ b/render.yaml
@@ -8,8 +8,8 @@ services:
     envVars:
       - key: NODE_ENV
         value: production
-      - key: DATABASE_URL
-        value: file:./dev.db
+      # IMPORTANT: Set DATABASE_URL in the Render dashboard (Supabase/Postgres connection string).
+      # Do not commit real credentials to this repo.
       - key: LOCAL_JWT_SECRET
         generateValue: true
       - key: NODE_VERSION
--
2.47.0.windows.2

