# PostgreSQL connection string. For local dev, use a local PostgreSQL server
# (e.g. via Docker: docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres).
# For production on Render, a free PostgreSQL database is auto-provisioned.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pksingh?schema=public

# Stable JWT secret. MUST be set to a strong, persistent value in production
# (do NOT use auto-generated values — those get regenerated on every deploy
# and will log all users out).
LOCAL_JWT_SECRET=pksingh-jwt-secret-change-this-to-a-strong-random-value

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
MAX_FILE_SIZE_MB=50
ALLOWED_MIME_TYPES=application/pdf,video/mp4,image/jpeg,image/png,image/webp
ADMIN_PASSWORD=adminpassword123
ADMIN_EMAIL=admin@pksingh.com
